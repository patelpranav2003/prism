# .env.example — copy to .env and fill in real values for local development.
# NEVER commit .env to version control.

# GitLab — used by the Artifact_Fetcher to download dbt CI artifacts
GITLAB_BASE_URL=https://gitlab.example.com/api/v4
GITLAB_PROJECT_ID=123
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# Databricks SQL warehouse ID (HTTP path segment, e.g. /sql/1.0/warehouses/<id>)
DATABRICKS_SQL_WAREHOUSE=your-warehouse-id

# Databricks connection (local dev only — not needed in Databricks Apps)
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapi-xxxxxxxxxxxxxxxxxxxx     # Personal Access Token

# LLM provider — set one (Anthropic takes priority if both are set)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx  # alternative: uses OpenRouter (openrouter.ai)

# bcrypt hash of the admin password (generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())")
ADMIN_PASSWORD_HASH=$2b$12$examplehashvalue...

# Optional tunables (defaults shown)
DEFAULT_ROW_LIMIT=1000
REFRESH_INTERVAL_HOURS=6
RETRY_INTERVAL_MINUTES=5

frontend/node_modules/
frontend/dist/
frontend/.vite/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db

# --- Databricks ---
.databricks/

# --- Docker ---
.docker/
